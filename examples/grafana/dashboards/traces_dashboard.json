      "id": 1,
      "options": {
        "showFilters": true,
        "table": {
          "columns": [
            "traceID",
            "startTime",
            "duration",
            "name",
            "statusCode"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=\"$service\"} && (name =~ \"(?i).*$span_filter.*\" || span.attributes.http.target =~ \"(?i).*$span_filter.*\" || span.attributes.db.statement =~ \"(?i).*$span_filter.*\")",
          "refId": "A"
        }
      ],
      "title": "Traces for $service",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(traces_spanmetrics_latency_bucket{service_name=\"$service\"}[$__rate_interval])) by (le)",
          "format": "heatmap",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Span Latency Heatmap",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"$service\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_calls_total{service_name=\"$service\"}[$__rate_interval]))",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    }

  "panels": [
    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "showFilters": true,
        "table": {
          "columns": [
            "traceID",
            "startTime",
            "duration",
            "name",
            "statusCode"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "links": [
            {
              "title": "Filter logs for this Trace ID",
              "url": "${__dashboard.url}?var-service=${service}&var-filter=${filter}&var-trace_id=${__value.raw}"
            }
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{resource.service.name=\"$service\" && (name =~ \"(?i)$filter\" || span.attributes.http.target =~ \"(?i)$filter\")}",
          "refId": "A"
        }
      ],
      "title": "Traces for $service (Filter: $filter)",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service_name=\"$service\"} |= \"$filter\" | json | trace_id =~ \"$trace_id\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Logs related to Trace ID: $trace_id",
      "type": "logs"
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
